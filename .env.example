# ===================== Cici Anova — Environment Variables =====================
# Copy this file to .env and fill in the actual values.
# .env is gitignored — secrets aman.

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=isi_token_disini

# URL chatbot server (default: localhost:8000)
CHATBOT_URL=http://localhost:8000/chat

# DeepSeek API Key (dari platform.deepseek.com)
DEEPSEEK_API_KEY=sk-isi_api_key_disini

# DeepSeek Chat Completion endpoint (dari docs resmi)
DEEPSEEK_API=https://api.deepseek.com/chat/completions

# Model (deepseek-v4-flash = latest, menggantikan deepseek-chat yg deprecate)
DEEPSEEK_MODEL=deepseek-v4-flash

# Google Sheets CSV URL (FAQ database)
GSHEET_CSV_URL=isi_url_csv_google_sheets_disini
