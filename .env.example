# ===================== Cici Anova — Environment Variables =====================
# Copy this file to .env and fill in the actual values.
# .env is gitignored — secrets aman.

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=***

# URL chatbot server (default: localhost:8000)
CHATBOT_URL=http://localhost:8000/chat

# Google Sheets CSV URL (FAQ database)
GSHEET_CSV_URL=***

# LLM Provider 1 — Utama (OpenAI-compatible endpoint)
LLM_API_1=https://opencode.ai/zen/go/v1/chat/completions
LLM_API_KEY_1=***
LLM_MODEL_1=deepseek-v4-flash

# LLM Provider 2 — Cadangan
LLM_API_2=https://api.deepseek.com/chat/completions
LLM_API_KEY_2=***
LLM_MODEL_2=deepseek-v4-flash

# Trusted user — skip anti-spam, daily limit, session rest (pisah pake koma)
# TRUSTED_CHAT_IDS=1267972859,987654321
# Kalo dikosongi, semua user kena limit

# LLM Provider 3 — Cadangan akhir (opsional, bisa kosong)
LLM_API_3=http://localhost:11434/v1/chat/completions
LLM_API_KEY_3=***
LLM_MODEL_3=qwen2.5:1.5b
