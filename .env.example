# ===================== Cici Anova — Environment Variables =====================
# Copy this file to .env and fill in the actual values.
# .env is gitignored — secrets aman.

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=***

# URL chatbot server (default: localhost:8000)
CHATBOT_URL=http://localhost:8000/chat

# Google Sheets CSV URL (FAQ database)
GSHEET_CSV_URL=***

# LLM Provider 1 — Utama (OpenCode Go / OpenRouter)
LLM_API_1=https://opencode.ai/zen/go/v1/chat/completions
LLM_API_KEY_1=***
LLM_MODEL_1=deepseek-v4-flash

# LLM Provider 2 — Gemini 2.5 Flash via Google AI (GRATIS!)
# Dapatkan API key: https://aistudio.google.com/apikey
LLM_API_2=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_API_KEY_2=AIza...
LLM_MODEL_2=gemini-2.5-flash

# LLM Provider 3 — Cadangan DeepSeek langsung
LLM_API_3=https://api.deepseek.com/chat/completions
LLM_API_KEY_3=***
LLM_MODEL_3=deepseek-chat

# LLM Provider 4 — Ollama lokal (opsional, buat offline)
# LLM_API_4=http://localhost:11434/v1/chat/completions
# LLM_API_KEY_4=***
# LLM_MODEL_4=gemma3n:e4b

# Trusted user — skip anti-spam & daily limit (pisah pake koma)
# TRUSTED_CHAT_IDS=1267972859,987654321
# Kalo dikosongi, semua user kena limit
