# ===================== Nara — Environment Variables =====================
# Copy this file to .env and fill in the actual values.
# .env is gitignored — secrets aman.

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=***

# URL chatbot server (default: localhost:8000)
CHATBOT_URL=http://localhost:8000/chat

# Google Sheets CSV URL (FAQ database)
GSHEET_CSV_URL=***

# LLM Provider 1 — Cloud API (OpenAI-compatible)
# Contoh: DeepSeek, OpenRouter, Gemini, dll.
LLM_API_1=https://api.deepseek.com/chat/completions
LLM_API_KEY_1=***
LLM_MODEL_1=deepseek-chat

# LLM Provider 2 — Ollama lokal (opsional, buat offline)
# Contoh: gemma3n:e4b, qwen2.5:1.5b, dll.
# LLM_API_2=http://localhost:11434/v1/chat/completions
# LLM_API_KEY_2=***
# LLM_MODEL_2=gemma3n:e4b

# Trusted user — skip anti-spam & daily limit (pisah pake koma)
# TRUSTED_CHAT_IDS=1267972859,987654321
# Kalo dikosongi, semua user kena limit
